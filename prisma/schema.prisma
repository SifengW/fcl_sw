generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url = env("POSTGRES_PRISMA_URL") // uses connection pooling
}

model batchForm {
  id        String     @default(cuid()) @id
  model     String
  level     Int
  quantity  Int
  serialNum String
  createdAt DateTime @default(now())
}